[Unit]
Description=Hermes Telegram kill switch / remote control (audit C1)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/spy-0dte-trader
EnvironmentFile=/root/spy-0dte-trader/.env
ExecStart=/usr/bin/python3 /root/spy-0dte-trader/hermes_system/kill_switch.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
